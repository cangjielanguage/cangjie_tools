{"jsonrpc":"2.0","method":"workspace/applyEdit","params":{"edit":{"changes":{"file:///home/wangjunwei/cppProjects/dev/cangjie_tools/cangjie-language-server/test/testChr/refactor/src/ExtractInterface/extract_interface.cj":[{"newText":"public interface Person <: Printable & Locatable {\n    func printName(): String\n    func age(): Int64\n    static func buildDefault(): Person\n    func secret(): String\n    func location(): String\n}\n","range":{"end":{"character":1,"line":64},"start":{"character":0,"line":38}}}]},"documentChanges":[{"kind":"create","uri":"file:///home/wangjunwei/cppProjects/dev/cangjie_tools/cangjie-language-server/test/testChr/refactor/src/ExtractInterface/personimpl.cj"},{"edits":[{"newText":"package default.ExtractInterface\n\nopen class PersonImpl <: Printable & Locatable {\n    var name: String\n\n    init(name: String) {\n        this.name = name\n    }\n\n    public func printName(): String {\n        return name\n    }\n\n    protected func age(): Int64 {\n        return 18\n    }\n\n    static redef func buildDefault(): Person {\n        return Person(\"default\")\n    }\n\n    private func secret(): String {\n        return \"hidden\"\n    }\n\n    public func location(): String {\n        return \"earth\"\n    }\n}\n","range":{"end":{"character":0,"line":0},"start":{"character":0,"line":0}}}],"textDocument":{"uri":"file:///home/wangjunwei/cppProjects/dev/cangjie_tools/cangjie-language-server/test/testChr/refactor/src/ExtractInterface/personimpl.cj","version":-1}}]}}}